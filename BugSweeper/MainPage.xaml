<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUI_Bugsweeper.MainPage"
             BackgroundColor="{DynamicResource AppBackground}">
    <StackLayout Padding="10" Spacing="10">
        <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand">
            <Picker x:Name="ThemePicker" Title="Theme" HorizontalOptions="Start" />
            <Button x:Name="NewGameButton" Text="New Game" HorizontalOptions="EndAndExpand" />
        </StackLayout>

        <StackLayout Orientation="Horizontal" Spacing="15">
            <Label Text="Mines:" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
            <Label x:Name="MinesLabel" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
            <Label Text="Time:" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
            <Label x:Name="TimeLabel" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
            <Label Text="Flags:" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
            <Label x:Name="FlagsLabel" TextColor="{DynamicResource AppText}" VerticalOptions="Center" />
        </StackLayout>

        <ScrollView>
            <Grid x:Name="BoardGrid" RowSpacing="2" ColumnSpacing="2" HorizontalOptions="Center" />
        </ScrollView>

        <StackLayout Orientation="Horizontal" HorizontalOptions="Center">
            <Button x:Name="FlagModeButton" Text="Flag Mode" />
        </StackLayout>
    </StackLayout>
</ContentPage>